---
import Layout from '../../components/layout/Layout.astro';
import PageTitle from '../../components/ui/PageTitle.astro';
import PageDescription from '../../components/ui/PageDescription.astro';
import Section from '../../components/ui/Section.astro';
import EventTileGrid from '../../components/ui/EventTileGrid.astro';
import EventWell from '../../components/ui/EventWell.astro';
import { gatheringsPage, gatherings } from '../../data/gatherings';

// Vite's import.meta.glob requires a static string, so we can't build per-entry
// glob patterns from data. Instead we glob all asset images once and filter by
// each entry's galleryPath at build time.
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/assets/**/*.{jpg,jpeg,png,webp,gif}',
  { eager: true }
);

function getGalleryImages(folder: string) {
  const prefix = `/assets/${folder}/`;
  return Object.fromEntries(Object.entries(allImages).filter(([path]) => path.startsWith(prefix)));
}
---

<Layout description={gatheringsPage.metaDescription} title={gatheringsPage.metaTitle}>
  <Section x-data="{ selected: 0 }">
    <PageTitle>{gatheringsPage.title}</PageTitle>
    <PageDescription>{gatheringsPage.description}</PageDescription>
    <EventTileGrid items={gatherings} />
    {
      gatherings.map((r, i) => (
        <EventWell
          index={i}
          title={r.title}
          description={r.metaDescription}
          galleryImages={r.galleryPath ? getGalleryImages(r.galleryPath) : undefined}
          galleryMetadata={r.galleryMetadata}
        />
      ))
    }
  </Section>
</Layout>
