---
import '@fontsource/mynerve/latin-400.css';
import stickyNote1 from '../../assets/sticky-note-1.png';
import stickyNote2 from '../../assets/sticky-note-2.png';
import stickyNote3 from '../../assets/sticky-note-3.png';
import stickyNote4 from '../../assets/sticky-note-4.png';
import logo from '../../assets/maybefiction-logo.png';
import Layout from '../components/layout/Layout.astro';
import PageDescription from '../components/ui/PageDescription.astro';
import StickyNoteLink from '../components/ui/StickyNoteLink.astro';
import { homePage } from '../data/home';
import '../styles/Home.scss';

const base = import.meta.env.BASE_URL;
const stickyNotes = [stickyNote1, stickyNote2, stickyNote3, stickyNote4];
const imageMap: Record<string, ImageMetadata> = Object.fromEntries(
  homePage.navLinks.map((link, i) => [link.href, stickyNotes[i]])
);

const innerLinks = homePage.navLinks.filter((l) => l.row === 'inner');
const outerLinks = homePage.navLinks.filter((l) => l.row === 'outer');
---

<Layout description={homePage.metaDescription} title={homePage.metaTitle}>
  <div class="home-main">
    <div class="home-intro-section">
      <div class="home-logo">
        <img src={logo.src} alt={homePage.logoAlt} />
      </div>
      <div class="home-description-center">
        <PageDescription>{homePage.tagline}</PageDescription>
      </div>
    </div>
    <div class="home-link-section">
      <div class="home-link-row home-link-row--inner">
        {
          innerLinks.map((link) => (
            <StickyNoteLink href={`${base}/${link.href}`} image={imageMap[link.href]}>
              {link.label}
            </StickyNoteLink>
          ))
        }
      </div>
      <div class="home-link-row home-link-row--outer">
        {
          outerLinks.map((link) => (
            <StickyNoteLink href={`${base}/${link.href}`} image={imageMap[link.href]}>
              {link.label}
            </StickyNoteLink>
          ))
        }
      </div>
    </div>
  </div>
</Layout>
