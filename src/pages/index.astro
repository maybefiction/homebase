---
import '@fontsource/mynerve/latin-400.css';
import stickyNote1 from '../../assets/sticky-note-1.png';
import stickyNote2 from '../../assets/sticky-note-2.png';
import stickyNote3 from '../../assets/sticky-note-3.png';
import stickyNote4 from '../../assets/sticky-note-4.png';
import logo from '../../assets/maybefiction-logo.png';
import Layout from '../components/layout/Layout.astro';
import PageDescription from '../components/ui/PageDescription';
import StickyNoteLink from '../components/ui/StickyNoteLink';
import '../styles/index.scss';

const base = import.meta.env.BASE_URL;
---

<Layout
  description="maybe:fiction — a creative collective."
  title="maybe:fiction"
>
  <div class="home-main">
    <div class="home-link-section">
      <div class="home-link-row home-link-row--inner">
        <StickyNoteLink href={`${base}/about`} image={stickyNote1}>About</StickyNoteLink>
        <StickyNoteLink href={`${base}/workshops`} image={stickyNote4}>Workshops</StickyNoteLink>
      </div>
      <div class="home-link-row home-link-row--outer">
        <StickyNoteLink href={`${base}/productions`} image={stickyNote2}>Productions</StickyNoteLink>
        <StickyNoteLink href={`${base}/rituals`} image={stickyNote3}>Rituals</StickyNoteLink>
      </div>
    </div>
    <div class="home-logo">
      <img
        src={logo.src}
        alt="maybe:fiction studios logo"
      />
    </div>
    <div class="home-description-center">
      <!-- <PageTitle>maybe:fiction</PageTitle> -->
      <PageDescription>transforming art into a social practice</PageDescription>
    </div>
  </div>
</Layout>
