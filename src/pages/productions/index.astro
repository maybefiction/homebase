---
import Layout from '../../components/layout/Layout.astro';
import PageTitle from '../../components/ui/PageTitle';
import PageDescription from '../../components/ui/PageDescription';
import Section from '../../components/ui/Section';
import { productionsPage, productions } from '../../data/productions';

const base = import.meta.env.BASE_URL;
---

<Layout
  description={productionsPage.metaDescription}
  title={productionsPage.metaTitle}
>
  <Section>
    <div class="page-header">
      <PageTitle>{productionsPage.title}</PageTitle>
      <PageDescription>{productionsPage.description}</PageDescription>
      <ul class="page-list">
        {productions.map((p) => (
          <li><a href={`${base}productions/${p.slug}`}>{p.title}</a></li>
        ))}
      </ul>
    </div>
  </Section>
</Layout>
