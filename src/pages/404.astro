---
import Button from '../components/ui/Button';
import Section from '../components/ui/Section';
import PageTitle from '../components/ui/PageTitle';
import PageDescription from '../components/ui/PageDescription';
import Layout from '../components/layout/Layout.astro';
import { notFoundPage } from '../data/errors';
import '../styles/404.scss';
---

<Layout
  description={notFoundPage.metaDescription}
  title={notFoundPage.metaTitle}
>
  <Section>
    <div class="error-page">
      <div class="error-page-header">
        <PageTitle>
          <div>{notFoundPage.errorCode}</div>
          <div>{notFoundPage.heading}</div>
        </PageTitle>
        <PageDescription>
          {notFoundPage.description}
        </PageDescription>
      </div>
      <Button href={import.meta.env.BASE_URL}>{notFoundPage.buttonText}</Button>
    </div>
  </Section>
</Layout>
