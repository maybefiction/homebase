---
import Layout from '../layouts/Layout.astro';
import PageTitle from '../components/ui/PageTitle';
import PageDescription from '../components/ui/PageDescription';
import { photos } from '../data/photography';
import { resolvePhotos, computeTagCounts, buildSidebarHtml } from '../utils/photography';
import '@fancyapps/ui/dist/fancybox/fancybox.css';
import '@fancyapps/ui/dist/fancybox/fancybox.sidebar.css';
import '../styles/photography.scss';

const validPhotos = resolvePhotos(photos);
const sortedTags = computeTagCounts(validPhotos);
---

<Layout
  description="Lorem ipsum dolor sit amet, consectetur adipiscing elit."
  title="Photography · Homebase"
>
  <section class="section">
    <div class="photo-header">
      <PageTitle>Photography</PageTitle>
      <PageDescription>
        <span class="gallery-description">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit.
          Gallery created with <a href="https://fancyapps.com/fancybox" target="_blank">Fancybox</a>.
        </span>
      </PageDescription>
    </div>
  </section>

  {
    validPhotos.length > 0 ? (
      <div x-data="{ selectedTag: '' }">
        <section class="filter-section">
          <button
            type="button"
            class="filter-btn"
            :class="{ 'active': selectedTag === '' }"
            @click="selectedTag = ''"
          >
            All <span class="filter-count">{validPhotos.length}</span>
          </button>
          {sortedTags.map(([tag, count]) => (
            <button
              type="button"
              class="filter-btn"
              :class={`{ 'active': selectedTag === '${tag}' }`}
              @click={`selectedTag = selectedTag === '${tag}' ? '' : '${tag}'`}
            >
              {tag} <span class="filter-count">{count}</span>
            </button>
          ))}
        </section>

        <section class="justified-gallery" id="gallery">
          {validPhotos.map((photo, index) => (
            <a
              style={`--width: ${photo.width}; --height: ${photo.height};`}
              href={photo.src}
              target="_blank"
              data-fancybox="gallery"
              data-caption={buildSidebarHtml(photo)}
              data-tags={JSON.stringify(photo.tags)}
              x-show="selectedTag === '' || JSON.parse($el.dataset.tags).includes(selectedTag)"
              x-transition:enter="transition ease-out duration-300"
              x-transition:enter-start="opacity-0"
              x-transition:enter-end="opacity-100"
              x-transition:leave="transition ease-in duration-200"
              x-transition:leave-start="opacity-100"
              x-transition:leave-end="opacity-0"
            >
              <img
                src={photo.src}
                alt=""
                loading={index < 3 ? 'eager' : 'lazy'}
              />
              <div class="overlay">
                {photo.caption && <span class="overlay-caption">{photo.caption}</span>}
                <div class="overlay-meta">
                  {photo.location && <span class="overlay-location">{photo.location}</span>}
                  <span class="overlay-date">{photo.formattedDate}</span>
                </div>
              </div>
            </a>
          ))}
        </section>
      </div>
    ) : (
      <section>
        <p class="photo-empty">Coming soon.</p>
      </section>
    )
  }
</Layout>

<script>
  import { Fancybox } from '@fancyapps/ui/dist/fancybox/';
  import { Sidebar } from '@fancyapps/ui/dist/fancybox/fancybox.sidebar.js';

  Fancybox.bind('[data-fancybox]', {
    theme: 'auto',
    plugins: { Sidebar },
    mainStyle: {
      '--f-button-width': '44px',
      '--f-button-height': '44px',
      '--f-button-border-radius': '50%',
      '--f-toolbar-padding': '16px',
      '--sidebar-width': 'clamp(200px, 30vw, 400px)',
      '--sidebar-padding': '1.5rem',
    },
    Carousel: {
      Arrows: false,
      Toolbar: {
        display: {
          left: [],
          middle: [],
          right: ['sidebar', 'close'],
        },
      },
      transition: 'slide',
    },
  });
</script>
