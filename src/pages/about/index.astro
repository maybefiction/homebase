---
import Layout from '../../components/layout/Layout.astro';
import About from './_About.astro';
import { aboutPage, creators } from '../../data/about';
import '../../styles/About.scss';
---

<Layout
  description={aboutPage.metaDescription}
  title={aboutPage.metaTitle}
>
  <About
    imageShape="square"
    imageAlt={aboutPage.logoAlt}
    name="maybe:fiction"
    bio={aboutPage.bio}
    socialLinks={aboutPage.socialLinks}
    cta={aboutPage.cta}
  />
  {creators.map((creator) => (
    <About
      reversed={creator.reversedDisplay}
      imageSrc={creator.imageUrl}
      imageAlt={creator.name}
      name={creator.name}
      bio={creator.bio}
      socialLinks={creator.socialLinks}
    />
  ))}
</Layout>
