---
import Layout from '../../components/layout/Layout.astro';
import PageTitle from '../../components/ui/PageTitle.astro';
import PageDescription from '../../components/ui/PageDescription.astro';
import Gallery from '../../components/ui/Gallery.astro';
import { workshopsPage } from '../../data/workshops';
import { galleryMeta } from '../../data/gallery';

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/assets/workshops/**/*.{jpg,jpeg,png,webp,gif}',
  { eager: true }
);
---

<Layout
  description={workshopsPage.metaDescription}
  title={workshopsPage.metaTitle}
>
  <section class="section">
    <div class="photo-header">
      <PageTitle>{workshopsPage.title}</PageTitle>
      <PageDescription>{workshopsPage.description}</PageDescription>
    </div>
  </section>

  <Gallery images={images} metadata={galleryMeta} />
</Layout>
