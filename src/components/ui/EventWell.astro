---
/**
 * Expandable detail panel shown when its index matches the Alpine.js `selected` state.
 *
 * Alpine context required (ancestor must declare):
 *   x-data="{ selected: null }"   – index of the currently selected item, or null
 *
 * Pair with <EventTileGrid> which toggles the `selected` value.
 */
import type { ImageMetadata } from 'astro';
import { marked } from 'marked';
import '../../styles/EventWell.scss';
import Gallery from './Gallery.astro';
import type { PhotoMeta } from './Gallery.astro';

interface Props {
  index: number;
  title: string;
  date?: string;
  description: string;
  galleryImages?: Record<string, { default: ImageMetadata }>;
  galleryMetadata?: Record<string, PhotoMeta>;
}

const { index, title, date, description, galleryImages, galleryMetadata } = Astro.props;
const descriptionHtml = await marked.parse(description);
---

<div class="detail-well" x-show={`selected === ${index}`}>
  <h3 class="detail-well-title">{title}</h3>
  {date && <p class="detail-well-date">{date}</p>}
  <div class="detail-well-description" set:html={descriptionHtml} />
  {
    galleryImages && Object.keys(galleryImages).length > 0 && (
      <Gallery images={galleryImages} metadata={galleryMetadata} />
    )
  }
</div>
